PORT=5000
# REQUIRED: Replace with a strong random secret before deploying.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=REPLACE_THIS_WITH_A_STRONG_RANDOM_SECRET
DB_MODE=sqlite
SQLITE_PATH=./data/dms.sqlite
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=postgres
PG_DATABASE=dms
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50
# For web/LAN deployment (browser-only, no Electron), set ALLOWED_ORIGINS=*
# For tighter security, list the exact origins e.g.: http://192.168.1.10:5000,http://10.42.0.1:5000
ALLOWED_ORIGINS=*
NODE_ENV=production
